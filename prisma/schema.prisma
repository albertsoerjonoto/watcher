// Watcher — Phase 1 schema
// Single-user-per-row design; multi-user ready.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(cuid())
  spotifyId        String             @unique
  displayName      String?
  accessToken      String
  refreshToken     String
  tokenExpiresAt   DateTime
  createdAt        DateTime           @default(now())
  playlists        Playlist[]
  pushSubscriptions PushSubscription[]
  deviceTokens     DeviceToken[] // reserved for Phase 2 (APNs)
}

model Playlist {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  spotifyId        String
  name             String
  imageUrl         String?
  ownerSpotifyId   String?
  ownerDisplayName String?
  snapshotId       String?
  status           String    @default("active") // active | unavailable
  notifyEnabled    Boolean   @default(true)
  sortOrder        Int       @default(0)
  lastCheckedAt    DateTime?
  imageBackfillAt  DateTime?
  createdAt        DateTime  @default(now())
  tracks           Track[]
  pollLogs         PollLog[]

  @@unique([userId, spotifyId])
  @@index([userId])
}

model Track {
  id              String   @id @default(cuid())
  playlistId      String
  playlist        Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  spotifyTrackId  String
  title           String
  artists         String // JSON array of names
  album           String?
  albumImageUrl   String?
  durationMs      Int
  addedAt         DateTime
  addedBySpotifyId String?
  firstSeenAt     DateTime @default(now())

  @@unique([playlistId, spotifyTrackId, addedAt])
  @@index([playlistId, addedAt])
  @@index([playlistId, firstSeenAt])
}

model PollLog {
  id          String   @id @default(cuid())
  playlistId  String?
  playlist    Playlist? @relation(fields: [playlistId], references: [id], onDelete: SetNull)
  startedAt   DateTime @default(now())
  durationMs  Int
  newTracks   Int      @default(0)
  error       String?

  @@index([playlistId, startedAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

// Cross-instance key/value state. Today it stores one row:
//   key = "spotify:rateLimitedUntil", value = ISO timestamp
// so every serverless instance (and cron worker) respects the same
// cooldown. Without this, a cold-started lambda would happily fire a
// fresh Spotify request right after the previous instance got 429'd,
// re-arming the rolling-30s counter and extending the penalty.
model AppState {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform  String // "ios" | "android"
  token     String   @unique
  createdAt DateTime @default(now())
}
