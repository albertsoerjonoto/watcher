// Watcher — Phase 1 schema
// Single-user-per-row design; multi-user ready.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(cuid())
  spotifyId        String             @unique
  displayName      String?
  accessToken      String
  refreshToken     String
  tokenExpiresAt   DateTime
  createdAt        DateTime           @default(now())
  // Section-level notification master switches. AND'd with each
  // playlist's own `notifyEnabled` flag in src/lib/poll.ts. All default
  // ON so existing users opt-in to every section automatically.
  notifyMain       Boolean            @default(true)
  notifyNew        Boolean            @default(true)
  notifyOther      Boolean            @default(true)
  playlists        Playlist[]
  pushSubscriptions PushSubscription[]
  deviceTokens     DeviceToken[] // reserved for Phase 2 (APNs)
  watchedUsers     WatchedUser[]
}

// A Spotify user whose public playlists are being watched. Distinct from
// `User` (the app/auth owner). One auth User can watch many Spotify users.
// Today's deployment has one WatchedUser (179366) backfilled from the
// existing Playlist.ownerSpotifyId data.
model WatchedUser {
  id                      String     @id @default(cuid())
  userId                  String
  user                    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  spotifyId               String     // the watched Spotify user id, e.g. "179366"
  displayName             String?
  imageUrl                String?
  createdAt               DateTime   @default(now())
  lastSyncedAt            DateTime?  // last fetchUserPublicPlaylists call
  // Discovery health. `discoveryStatus` drives whether the cron
  // auto-rediscovery loop targets this user; `discoveryVia` echoes
  // the tier that produced the most recent successful enumeration so
  // the dashboard can render "via search" / "auto-retry every 6h".
  // `lastDiscoveryAttemptAt` gates the cron retry interval (default 6h).
  // Values for discoveryStatus: "ok" | "partial" | "blocked".
  // Values for discoveryVia: matches DiscoveryVia in src/lib/spotify.ts.
  discoveryStatus         String     @default("ok")
  discoveryVia            String?
  lastDiscoveryAttemptAt  DateTime?
  playlists               Playlist[]

  @@unique([userId, spotifyId])
  @@index([userId])
}

model Playlist {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Watched-user attachment. Nullable because POST /api/playlists deliberately
  // makes no Spotify call on the hot path — ownerSpotifyId isn't known until
  // the first successful pollPlaylist, which is when watchedUserId is wired
  // up via the post-poll attach hook in src/lib/poll.ts.
  watchedUserId    String?
  watchedUser      WatchedUser? @relation(fields: [watchedUserId], references: [id], onDelete: Restrict)
  spotifyId        String
  name             String
  imageUrl         String?
  ownerSpotifyId   String?
  ownerDisplayName String?
  snapshotId       String?
  status           String    @default("active") // active | unavailable
  notifyEnabled    Boolean   @default(true)
  // Section in the dashboard. "main" = curated (cap MAX_MAIN_PER_WATCHED_USER,
  // notifications + 10min staleness), "new" = triage queue from sync diff
  // (notifications + 10min staleness), "other" = passive listing (12h
  // staleness, no track-add notifications).
  section          String    @default("main")
  sortOrder        Int       @default(0)
  lastCheckedAt    DateTime?
  imageBackfillAt  DateTime?
  createdAt        DateTime  @default(now())
  tracks           Track[]
  pollLogs         PollLog[]

  @@unique([userId, spotifyId])
  @@index([userId])
  @@index([watchedUserId, section])
}

model Track {
  id              String   @id @default(cuid())
  playlistId      String
  playlist        Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  spotifyTrackId  String
  title           String
  artists         String // JSON array of names
  album           String?
  albumImageUrl   String?
  durationMs      Int
  addedAt         DateTime
  addedBySpotifyId String?
  firstSeenAt     DateTime @default(now())

  @@unique([playlistId, spotifyTrackId, addedAt])
  @@index([playlistId, addedAt])
  @@index([playlistId, firstSeenAt])
}

model PollLog {
  id          String   @id @default(cuid())
  playlistId  String?
  playlist    Playlist? @relation(fields: [playlistId], references: [id], onDelete: SetNull)
  startedAt   DateTime @default(now())
  durationMs  Int
  newTracks   Int      @default(0)
  error       String?

  @@index([playlistId, startedAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

// Cross-instance key/value state. Today it stores one row:
//   key = "spotify:rateLimitedUntil", value = ISO timestamp
// so every serverless instance (and cron worker) respects the same
// cooldown. Without this, a cold-started lambda would happily fire a
// fresh Spotify request right after the previous instance got 429'd,
// re-arming the rolling-30s counter and extending the penalty.
model AppState {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform  String // "ios" | "android"
  token     String   @unique
  createdAt DateTime @default(now())
}
